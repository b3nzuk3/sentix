{
  "name": "@sentix/api",
  "version": "0.1.0",
  "main": "dist/server.js",
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prisma": "prisma",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:generate": "cross-env PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^10.1.1",
    "@fastify/jwt": "^6.7.1",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^7.6.0",
    "@fastify/websocket": "^5.0.1",
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.29.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^8.0.0",
    "pino-pretty": "^8.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@sentix/core": "workspace:*",
    "@sentix/prompts": "workspace:*",
    "@sentix/queue": "workspace:*",
    "@sentix/types": "workspace:*",
    "@types/bcrypt": "^5.0.0",
    "@types/jest": "^29.5.0",
    "cross-env": "^7.0.0",
    "fastify-type-provider-zod": "^5.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.0.0"
  }
}
